{
  "$schema": "https://ateeducacion.github.io/omeka-s-playground/assets/blueprints/blueprint-schema.json",
  "debug": {
    "enabled": true
  },
  "landingPage": "/admin",
  "siteOptions": {
    "title": "REA ATE Playground",
    "locale": "es",
    "timezone": "Atlantic/Canary"
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@example.com",
      "password": "password",

  "themes": [
    {
      "name": "rea-ate",
      "source": {
        "type": "url",
        "url": "https://github.com/ateeducacion/omeka-s-theme-rea-ate/archive/refs/heads/master.zip"
      }
    }
  ],
  "site": {
    "title": "REA ATE Demo",
    "slug": "demo",
    "theme": "rea-ate",
    "summary": "Minimal install to preview the REA ATE theme (with AdvancedSearch) in Omeka S Playground.",

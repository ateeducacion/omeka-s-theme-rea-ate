<?php
$translate  = $this->plugin('translate');
$escape     = $this->plugin('escapeHtml');
$this->inlineScript()->appendFile($this->assetUrl('js/advanced-search.js'));
$this->htmlElement('body')->appendAttribute('class', 'items search advanced-search-edu');

$query = $this->params()->fromQuery();

// Property ID lookups — installation-independent.
$eduPropTerms = [
    'lrmi:educationalLevel'     => 'Nivel educativo',
    'lrmi:learningResourceType' => 'Tipo de recurso',
    'schema:about'              => 'Materia o tema',
    'lrmi:educationalRole'      => 'Audiencia destinataria',
    'lrmi:timeRequired'         => 'Duración',
];
$eduProps = [];
foreach (array_keys($eduPropTerms) as $term) {
    try {
        $prop = $this->api()->searchOne('properties', ['term' => $term])->getContent();
        if ($prop) $eduProps[$term] = $prop->id();
    } catch (\Exception $e) {}
}

// Build prop-id → array of text values from the incoming query (supports multi-value).
$existingPropValues = [];
foreach ($query['property'] ?? [] as $ep) {
    $pid = (int) ($ep['property'] ?? 0);
    if ($pid && isset($ep['text']) && $ep['text'] !== '') {
        $existingPropValues[$pid][] = $ep['text'];
    }
}

// Returns all existing text values for a property term (array).
$propVals = function (string $term) use ($eduProps, $existingPropValues): array {
    return isset($eduProps[$term]) ? ($existingPropValues[$eduProps[$term]] ?? []) : [];
};

// Pre-select lrmi:LearningResource class unless already set by the user.
$lrmiClassId = null;
if (empty($query['resource_class_id'])) {
    try {
        $cls = $this->api()->searchOne('resource_classes', ['term' => 'lrmi:LearningResource'])->getContent();
        if ($cls) {
            $lrmiClassId = $cls->id();
            $query['resource_class_id'] = [$lrmiClassId];
        }
    } catch (\Exception $e) {}
} else {
    $lrmiClassId = (int) ($query['resource_class_id'][0] ?? 0) ?: null;
}

// Total resources for count badge.
$totalResources = null;
if ($lrmiClassId) {
    try {
        $totalResources = $this->api()->search('items', [
            'resource_class_id' => [$lrmiClassId], 'limit' => 0,
        ])->getTotalResults();
    } catch (\Exception $e) {}
}

// Available item sets for the collections filter.
$availableItemSets = [];
try {
    $availableItemSets = $this->api()->search('item_sets', [
        'sort_by' => 'dcterms:title', 'sort_order' => 'asc', 'limit' => 100,
    ])->getContent();
} catch (\Exception $e) {}
$selectedItemSets = array_map('intval', $query['item_set_id'] ?? []);
$itemSetTitles    = [];
foreach ($availableItemSets as $_is) {
    $itemSetTitles[$_is->id()] = $_is->displayTitle();
}

// Chip option lists.
$levelChips = [
    'Educación Infantil', 'Educación Primaria',
    '1º ESO', '2º ESO', '3º ESO', '4º ESO',
    '1º Bachillerato', '2º Bachillerato',
    'FP Básica', 'FP Grado Medio', 'FP Grado Superior',
];
$typeChips = [
    ['v' => 'Vídeo',                    'i' => 'play_circle'],
    ['v' => 'SCORM',                    'i' => 'interactive_space'],
    ['v' => 'PDF',                      'i' => 'picture_as_pdf'],
    ['v' => 'Texto',                    'i' => 'description'],
    ['v' => 'Infografía',               'i' => 'image'],
    ['v' => 'Situación de aprendizaje', 'i' => 'account_tree'],
    ['v' => 'Objeto de aprendizaje',    'i' => 'school'],
];
$audienceChips = ['Alumnado', 'Docente', 'Familias', 'NEAE', 'Centros educativos'];

// Pre-selected chip values per group (arrays for multi-select).
$lvlVals      = $propVals('lrmi:educationalLevel');
$typeVals     = $propVals('lrmi:learningResourceType');
$audienceVals = $propVals('lrmi:educationalRole');
$subjectVals  = $propVals('schema:about');   // multi-value pills

// Duration range: Omeka-S only supports eq/in/sw/ew/res/ex/dt for property queries.
// gte/lte are silently ignored. Workaround: build OR conditions for each matching
// integer value from the actual stored data. Values are passed to JS as JSON array.
// Display uses custom dur_min/dur_max params (unknown to Omeka, just for UI state).
$durPropId  = $eduProps['lrmi:timeRequired'] ?? 0;
$durationMin = (string) ($query['dur_min'] ?? '');
$durationMax = (string) ($query['dur_max'] ?? '');

// Query distinct integer values for this property via Omeka-S API.
// Used by JS to build exact OR-eq conditions (Omeka doesn't support gte/lte on literals).
$durValues = null; // null → JS falls back to multiples-of-5
if ($durPropId) {
    try {
        $durItems = $this->api()->search('items', [
            'property' => [['property' => (int) $durPropId, 'type' => 'ex']],
            'limit'    => 500,
        ])->getContent();
        $durValSet = [];
        foreach ($durItems as $dItem) {
            $dVal = $dItem->value('lrmi:timeRequired');
            if ($dVal) {
                $txt = trim($dVal->value());
                if (ctype_digit($txt) && (int) $txt > 0) {
                    $durValSet[(int) $txt] = true;
                }
            }
        }
        ksort($durValSet);
        $durValues = array_keys($durValSet);
    } catch (\Throwable $e) {
        $durValues = null;
    }
}

// Subject options for dropdown.
$subjectOptions = [
    'Biología y Geología', 'Matemáticas', 'Lengua Castellana y Literatura',
    'Lengua extranjera Inglés', 'Lengua extranjera Francés',
    'Geografía e Historia', 'Historia de Canarias',
    'Literatura Canaria', 'Medio Natural Canario',
    'Física y Química', 'Tecnología e Ingeniería', 'Economía',
    'Filosofía', 'Educación Física', 'Música', 'Artes Plásticas',
];

$sortBy    = $escape($query['sort_by'] ?? '');
$sortOrder = $escape($query['sort_order'] ?? 'desc');
?>


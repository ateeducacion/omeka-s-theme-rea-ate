<?php
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');
$escapeAttr = $this->plugin('escapeHtmlAttr');
$this->inlineScript()->appendFile($this->assetUrl('js/browse.js'));
$this->htmlElement('body')->appendAttribute('class', 'item resource browse');

$user = $this->identity();
$adminBasePath = $user ? $this->url('admin') : '';
$showToolboxForUser = $this->CanEditInCurrentSite();

$filterLocale = (bool) $this->siteSetting('filter_locale_values');
$lang = $this->lang();
$valueLang = $filterLocale ? [$lang, ''] : null;

$api = $this->api();
$site = $this->currentSite();
$query = $this->params()->fromQuery();
$itemSetShow = isset($itemSet);
if ($itemSetShow) {
    $this->headLink()->appendStylesheet($this->assetUrl('css/resource-page-blocks.css', 'Omeka'));

    $mainBlockContent = $this->resourcePageBlocks($itemSet);
    $mainHasBlocks = $mainBlockContent->hasBlocks();
    $leftSidebarBlockContent = $this->resourcePageBlocks($itemSet, 'left');
    $leftSidebarHasBlocks = $leftSidebarBlockContent->hasBlocks();
    $rightSidebarBlockContent = $this->resourcePageBlocks($itemSet, 'right');
    $rightSidebarHasBlocks = $rightSidebarBlockContent->hasBlocks();

    $this->htmlElement('body')->appendAttribute('class', 'item-set');
    $query['item_set_id'] = $itemSet->id();
}

$layoutSetting = $this->themeSetting('browse_layout', 'grid');
$gridState = ($layoutSetting == 'togglegrid') ? 'disabled' : '';
$listState = ($layoutSetting == 'togglelist') ? 'disabled' : '';
$isGrid = strpos($layoutSetting, 'grid') !== false;
$bodyTerm = $this->siteSetting('browse_body_property_term');
$currentView = $isGrid ? 'grid' : 'list';

if (isset($_GET['view'])) {
    if ($_GET['view'] === 'list') {
        $gridState = '';
        $listState = 'disabled';
        $isGrid = false;
        $currentView = 'list';
    } else {
        $gridState = 'disabled';
        $listState = '';
        $isGrid = true;
        $currentView = 'grid';
    }
}

$countQuery = $query;
unset($countQuery['view'], $countQuery['page']);
$countQuery['site_id'] = $site->id();
$countQuery['is_public'] = true;
$totalResults = $api->search('items', $countQuery)->getTotalResults();
$activeFilters = $this->searchFilters();

$searchAction = parse_url($_SERVER['REQUEST_URI'] ?? '', PHP_URL_PATH) ?: $this->url(
    'site/resource',
    ['site-slug' => $site->slug(), 'controller' => 'item', 'action' => 'browse'],
    true
);
$fulltextSearch = (string) ($query['fulltext_search'] ?? '');
$sortSelector = $this->browse()->renderSortSelector('items');

$renderHiddenInputs = function (string $name, $value) use (&$renderHiddenInputs, $escapeAttr): string {
    if (is_array($value)) {
        $html = '';
        foreach ($value as $key => $nestedValue) {
            $html .= $renderHiddenInputs(sprintf('%s[%s]', $name, $key), $nestedValue);
        }
        return $html;
    }

    if ($value === null || $value === '') {
        return '';
    }

    return sprintf(
        '<input type="hidden" name="%s" value="%s">',
        $escapeAttr($name),
        $escapeAttr((string) $value)
    );
};

$getFirstValue = function ($resource, array $terms) {
    foreach ($terms as $term) {
        $value = $resource->value($term);
        if ($value) {
            return $value;
        }
    }
    return null;
};

// Returns display string for a value: title if resource-linked, raw string otherwise.
$displayValue = function ($value) use ($valueLang) {
    if (!$value) return '';
    if ($value->type() === 'resource') {
        $linked = $value->valueResource();
        return $linked ? $linked->displayTitle(null, $valueLang) : (string) $value;
    }
    return (string) $value;
};
?>

<?php if ($itemSetShow): ?>
    <?php if (($mainHasBlocks && $blockContent = $mainBlockContent->getBlocks())
        || ($leftSidebarHasBlocks && $blockContent = $leftSidebarBlockContent->getBlocks())
        || ($rightSidebarHasBlocks && $blockContent = $rightSidebarBlockContent->getBlocks())): ?>


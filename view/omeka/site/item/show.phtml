<?php
$translate = $this->plugin('translate');
$escape    = $this->plugin('escapeHtml');

$this->headLink()->appendStylesheet($this->assetUrl('css/resource-page-blocks.css', 'Omeka'));
$this->htmlElement('body')->appendAttribute('class', 'item resource show');

$user = $this->identity();
$adminBasePath = $user ? $this->url('admin') : '';
$showToolboxForUser = $this->CanEditInCurrentSite();

$filterLocale = (bool) $this->siteSetting('filter_locale_values');
$lang = $this->lang();
$valueLang = $filterLocale ? [$lang, ''] : null;

// Regions
$mainBlockContent = $this->resourcePageBlocks($item);
$mainHasBlocks = $mainBlockContent->hasBlocks();
$leftSidebarBlockContent = $this->resourcePageBlocks($item, 'left');
$leftSidebarHasBlocks = $leftSidebarBlockContent->hasBlocks();
$rightSidebarBlockContent = $this->resourcePageBlocks($item, 'right');
$rightSidebarHasBlocks = $rightSidebarBlockContent->hasBlocks();

$plugins    = $this->getHelperPluginManager();
$breadcrumbs = $plugins->has('breadcrumbs') ? $plugins->get('breadcrumbs') : null;
?>

<?php if ($breadcrumbs): ?>
<div class="breadcrumbs-parent">
    <?= $breadcrumbs() ?>
</div>
<?php endif; ?>

<div class="item-hero">
    <div class="item-hero__left">

        <div class="item-hero__eyebrow">
            <?php
            $resourceTypeValue = $item->value('lrmi:learningResourceType');
            if ($resourceTypeValue):
                $rawType = (string) $resourceTypeValue;

                // If the value is a URI, extract the last path/hash segment.
                $typeLabel = preg_match('#[/#]([^/#]+)\/?$#', $rawType, $m) ? $m[1] : $rawType;
                // camelCase → space-separated words (e.g. "learningActivity" → "Learning Activity").
                $typeLabel = preg_replace('/([a-z])([A-Z])/', '$1 $2', $typeLabel);
                $typeLabel = ucfirst($typeLabel);

                // Truncate to 35 chars; keep full label for the title attribute.
                $truncated    = mb_strlen($typeLabel) > 35;
                $displayLabel = $truncated ? mb_substr($typeLabel, 0, 34) . '…' : $typeLabel;

                // Map common resource-type keywords to contextual Material Symbols icons.
                $typeLower = mb_strtolower($typeLabel);
                $icon      = 'school'; // default
                foreach ([
                    'vídeo'        => 'smart_display',
                    'video'        => 'smart_display',
                    'audio'        => 'headphones',
                    'podcast'      => 'headphones',
                    'documento'    => 'article',
                    'document'     => 'article',
                    'interactiv'   => 'touch_app',
                    'juego'        => 'sports_esports',
                    'game'         => 'sports_esports',
                    'cuestionario' => 'quiz',
                    'quiz'         => 'quiz',
                    'evaluaci'     => 'quiz',
                    'assessment'   => 'quiz',
                    'presentaci'   => 'slideshow',
                    'presentation' => 'slideshow',
                    'lección'      => 'menu_book',
                    'lesson'       => 'menu_book',
                    'lectur'       => 'menu_book',
                    'unidad'       => 'folder_open',
                    'unit'         => 'folder_open',
                    'simulaci'     => 'model_training',
                    'simulation'   => 'model_training',
                    'actividad'    => 'assignment',
                    'activity'     => 'assignment',
                ] as $keyword => $mappedIcon) {
                    if (str_contains($typeLower, $keyword)) {
                        $icon = $mappedIcon;
                        break;
                    }
                }
            ?>
            <span class="resource-type-badge"<?php if ($truncated): ?> title="<?php echo $escape($typeLabel); ?>"<?php endif; ?>>
                <span class="material-symbols-outlined" aria-hidden="true"><?php echo $icon; ?></span>
                <?php echo $escape($displayLabel); ?>
            </span>
            <?php endif; ?>

            <?php foreach ($item->itemSets() as $itemSet): ?>
            <a href="<?php echo $escape($itemSet->siteUrl()); ?>"
               class="item-set-pill">
                <?php echo $escape($itemSet->displayTitle(null, $valueLang)); ?>
            </a>
            <?php endforeach; ?>
        </div>

        <h1 class="item-hero__title">
            <?php echo $escape($item->displayTitle(null, $valueLang)); ?>
        </h1>

    </div>

    <div class="item-hero__right">
        <?php
        $createdDate = $item->created();
        $diff = (new DateTime())->diff($createdDate);
        $daysAgo = $diff->days;
        ?>
        <span class="days-ago-tag">
            <?php echo $escape(sprintf(
                $translate($daysAgo == 1 ? '%s day ago' : '%s days ago'),
                $daysAgo
            )); ?>
        </span>

        <?php if ($user && $showToolboxForUser): ?>
        <div class="admin-actions">
            <a href="<?php echo $escape($adminBasePath . '/item/' . $item->id() . '/edit'); ?>"
               class="admin-btn"
               title="<?php echo $escape($translate('Edit')); ?>"
               aria-label="<?php echo $escape($translate('Edit')); ?>">
                <span class="material-symbols-outlined">edit</span>
            </a>
            <a href="<?php echo $escape($adminBasePath . '/item/' . $item->id() . '/edit#item-media'); ?>"
               class="admin-btn"
               title="<?php echo $escape($translate('Add media')); ?>"
               aria-label="<?php echo $escape($translate('Add media')); ?>">
                <span class="material-symbols-outlined">add_photo_alternate</span>
            </a>
            <button class="admin-btn admin-btn--delete"
                    data-item-id="<?php echo $item->id(); ?>"
                    data-item-title="<?php echo $escape($item->displayTitle(null, $valueLang)); ?>"
                    title="<?php echo $escape($translate('Delete')); ?>"
                    aria-label="<?php echo $escape($translate('Delete')); ?>">
                <span class="material-symbols-outlined">delete</span>
            </button>
        </div>
        <?php endif; ?>
    </div>
</div>

<?php $this->trigger('view.show.before'); ?>

<?php if ($mainHasBlocks || $leftSidebarHasBlocks || $rightSidebarHasBlocks): ?>
<div class="item-body">

    <?php if ($leftSidebarHasBlocks): ?>
    <aside class="item-sidebar item-sidebar--left">
        <?php echo $leftSidebarBlockContent->getBlocks(); ?>
    </aside>
    <?php endif; ?>

    <?php if ($mainHasBlocks): ?>
    <main class="item-main" id="main-content">
        <?php echo $mainBlockContent->getBlocks(); ?>
    </main>
    <?php endif; ?>

    <?php if ($rightSidebarHasBlocks): ?>
    <aside class="item-sidebar item-sidebar--right">
        <?php echo $rightSidebarBlockContent->getBlocks(); ?>

    </aside>
    <?php endif; ?>

</div>
<?php endif; ?>

<?php $this->trigger('view.show.after'); ?>

<?php if ($user && $showToolboxForUser): ?>
<?php
    $csrfElement = new \Laminas\Form\Element\Csrf('confirmform_csrf');
    $csrfToken = $csrfElement->getCsrfValidator()->getHash(true);
?>
<div id="delete-confirm-modal" class="delete-confirm-modal" style="display:none;"
     data-csrf-token="<?php echo $escape($csrfToken); ?>"
     data-admin-base-path="<?php echo $escape($this->url('admin')); ?>">
    <div class="delete-confirm-modal__overlay"></div>
    <div class="delete-confirm-modal__content">
        <h3><?php echo $escape($translate('Confirm Delete')); ?></h3>
        <p><?php echo $escape($translate('Are you sure you want to delete the item')); ?> "<span id="delete-item-title"></span>"?</p>
        <div class="delete-confirm-modal__actions">
            <button type="button" class="button btn--secondary" id="delete-cancel"><?php echo $escape($translate('Cancel')); ?></button>
            <button type="button" class="button" id="delete-confirm"><?php echo $escape($translate('Confirm Delete')); ?></button>
        </div>
    </div>
</div>
<?php endif; ?>

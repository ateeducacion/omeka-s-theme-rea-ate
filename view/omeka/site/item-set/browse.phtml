<?php
$translate = $this->plugin('translate');
$escape    = $this->plugin('escapeHtml');
$escapeAttr = $this->plugin('escapeHtmlAttr');
$this->htmlElement('body')->appendAttribute('class', 'item-set resource browse');

$api    = $this->api();
$siteId = $this->currentSite()->id();

// Pre-compute visible sets (with item count, skipping empty)
$visibleSets = [];
foreach ($itemSets as $itemSet) {
    $count = $api->search('items', [
        'item_set_id' => $itemSet->id(),
        'site_id'     => $siteId,
        'is_public'   => true,
        'limit'       => 1,
    ])->getTotalResults();
    if ($count > 0) {
        $visibleSets[] = ['itemSet' => $itemSet, 'count' => $count];
    }
}

// Build filter select options from visible sets
$etapas = $niveles = $tematicas = [];
foreach ($visibleSets as $entry) {
    $is = $entry['itemSet'];

    // Etapa: lrmi:educationalAlignment
    $etapaValues = $is->value('lrmi:educationalAlignment', ['all' => true]) ?: [];
    foreach ($etapaValues as $v) {
        $label = (string) $v->value();
        $slug  = implode('', $this->SlugifyValues([$v]));
        if ($slug !== '' && !isset($etapas[$slug])) {
            $etapas[$slug] = $label;
        }
    }

    // Nivel: lrmi:educationalLevel (preferred) or lom:educationalLevel (fallback)
    $nivelValues = $is->value('lrmi:educationalLevel', ['all' => true]) ?: $is->value('lom:educationalLevel', ['all' => true]) ?: [];
    foreach ($nivelValues as $v) {
        $label = (string) $v->value();
        $slug  = implode('', $this->SlugifyValues([$v]));
        if ($slug !== '' && !isset($niveles[$slug])) {
            $niveles[$slug] = $label;
        }
    }

    // Temática: schema:about (preferred) or dcterms:subject (fallback)
    $temaValues = $is->value('schema:about', ['all' => true]) ?: $is->value('dcterms:subject', ['all' => true]) ?: [];
    foreach ($temaValues as $v) {
        $label = (string) $v->value();
        $slug  = implode('', $this->SlugifyValues([$v]));
        if ($slug !== '' && !isset($tematicas[$slug])) {
            $tematicas[$slug] = $label;
        }
    }
}
?>

<!-- PAGE HEADER -->
<header class="item-set-browse-header">
    <div class="item-set-browse-header__text">
        <h1 class="item-set-browse-header__title"><?= $escape($translate('Colecciones')) ?></h1>
        <p class="item-set-browse-header__subtitle"><?= $escape($translate('Recursos agrupados por colección temática.')) ?></p>
    </div>

    <!-- FILTER BAR (Integrated) -->
    <div class="collection-filter-bar" role="region" aria-label="<?= $escapeAttr($translate('Filtrar colecciones')) ?>">
        <span class="collection-filter-bar__label">
            <span class="material-symbols-outlined" aria-hidden="true">tune</span>
            <?= $escape($translate('Filtrar')) ?>
        </span>

        <?php if ($etapas): ?>
        <div class="collection-filter-select">
            <select id="filter-etapa" aria-label="<?= $escapeAttr($translate('Filtrar por etapa')) ?>">
                <option value=""><?= $escape($translate('Etapa')) ?></option>
                <?php foreach ($etapas as $slug => $label): ?>
                    <option value="<?= $escapeAttr($slug) ?>"><?= $escape($label) ?></option>
                <?php endforeach; ?>
            </select>
        </div>
        <?php endif; ?>

        <?php if ($niveles): ?>
        <div class="collection-filter-select">
            <select id="filter-nivel" aria-label="<?= $escapeAttr($translate('Filtrar por nivel')) ?>">
                <option value=""><?= $escape($translate('Nivel')) ?></option>
                <?php foreach ($niveles as $slug => $label): ?>
                    <option value="<?= $escapeAttr($slug) ?>"><?= $escape($label) ?></option>
                <?php endforeach; ?>
            </select>
        </div>
        <?php endif; ?>

        <?php if ($tematicas): ?>
        <div class="collection-filter-select">
            <select id="filter-tematica" aria-label="<?= $escapeAttr($translate('Filtrar por temática')) ?>">
                <option value=""><?= $escape($translate('Temática')) ?></option>
                <?php foreach ($tematicas as $slug => $label): ?>
                    <option value="<?= $escapeAttr($slug) ?>"><?= $escape($label) ?></option>
                <?php endforeach; ?>
            </select>
        </div>
        <?php endif; ?>

        <button type="button" class="collection-filter-clear" id="collection-filter-clear">
            <span class="material-symbols-outlined" aria-hidden="true">close</span>
            <?= $escape($translate('Limpiar')) ?>
        </button>
    </div>
</header>

<?php $this->trigger('view.browse.before'); ?>

<div class="item-set-browse-results-info">
    <div class="item-set-browse-header__count">
        <strong><?= count($visibleSets) ?></strong> <?= $escape($translate('colecciones')) ?>
    </div>
</div>

<!-- COLLECTIONS GRID -->
<div class="collections-grid" id="collections-grid">

    <?php foreach ($visibleSets as $entry):
        $itemSet  = $entry['itemSet'];
        $itemCount = $entry['count'];

        $coverUrl = $itemSet->thumbnailDisplayUrl('large');

        $etapaSlugs   = implode(' ', $this->SlugifyValues($itemSet->value('lrmi:educationalAlignment', ['all' => true]) ?: []));
        $nivelSlugs   = implode(' ', $this->SlugifyValues($itemSet->value('lrmi:educationalLevel',     ['all' => true]) ?: $itemSet->value('lom:educationalLevel', ['all' => true]) ?: []));
        $temaSlugs    = implode(' ', $this->SlugifyValues($itemSet->value('schema:about',           ['all' => true]) ?: $itemSet->value('dcterms:subject',         ['all' => true]) ?: []));

        $description  = $itemSet->displayDescription();
    ?>
    <a href="<?= $escapeAttr($itemSet->siteUrl()) ?>" class="collection-card"
       data-etapa="<?= $escapeAttr($etapaSlugs) ?>"
       data-nivel="<?= $escapeAttr($nivelSlugs) ?>"
       data-tematica="<?= $escapeAttr($temaSlugs) ?>">

        <?php if ($coverUrl): ?>
            <div class="collection-card__cover">
                <img src="<?= $escapeAttr($coverUrl) ?>"
                     alt="<?= $escapeAttr($itemSet->displayTitle()) ?>">
            </div>
        <?php else: ?>
            <div class="collection-card__cover collection-card__cover--fallback">
                <span class="material-symbols-outlined" aria-hidden="true">folder_open</span>
            </div>
        <?php endif; ?>

        <div class="collection-card__title-strip">
            <h2 class="collection-card__title"><?= $escape($itemSet->displayTitle()) ?></h2>
            <span class="collection-card__count-pill">
                <?= (int) $itemCount ?> <?= $escape($translate('recursos')) ?>
            </span>
        </div>

        <div class="collection-card__body">
            <?php if ($description): ?>
                <p class="collection-card__description"><?= $escape($description) ?></p>
            <?php endif; ?>
            <span class="collection-card__cta">
                <?= $escape($translate('Ver colección')) ?>
                <span class="collection-card__cta-arrow">
                    <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                </span>
            </span>
        </div>
    </a>
    <?php endforeach; ?>

    <div class="collections-grid__empty-state" id="collections-empty-state" hidden>
        <span class="material-symbols-outlined" aria-hidden="true">inventory_2</span>
        <?= $escape($translate('No hay colecciones que coincidan con los filtros seleccionados.')) ?>
    </div>

</div>

<?php $this->trigger('view.browse.after'); ?>

<?= $this->pagination() ?>

<?= $this->partial('omeka/site/item-set/_browse-filter-script') ?>

<?php
$translate  = $this->plugin('translate');
$escape     = $this->plugin('escapeHtml');
$escapeAttr = $this->plugin('escapeHtmlAttr');
$hyperlink  = $this->plugin('hyperlink');
$url        = $this->plugin('url');

$this->inlineScript()->appendFile($this->assetUrl('js/browse.js'));
$this->htmlElement('body')->appendAttribute('class', 'index search');

$filterLocale = (bool) $this->siteSetting('filter_locale_values');
$lang         = $this->lang();
$valueLang    = $filterLocale ? [$lang, ''] : null;

$bodyTerm = $this->siteSetting('browse_body_property_term');

$getFirstValue = function ($resource, array $terms) {
    foreach ($terms as $term) {
        $v = $resource->value($term);
        if ($v) return $v;
    }
    return null;
};

$displayValue = function ($value) use ($valueLang) {
    if (!$value) return '';
    if ($value->type() === 'resource') {
        $linked = $value->valueResource();
        return $linked ? $linked->displayTitle(null, $valueLang) : (string) $value;
    }
    return (string) $value;
};

$itemResults = $results['items'] ?? null;
$totalItems  = $itemResults ? (int) $itemResults['total'] : 0;
$itemList    = $itemResults ? $itemResults['resources'] : [];

$hasQuery = isset($query) && trim((string) $query) !== '';
?>

<section class="resource-browse-page">

    <header class="resource-browse-header">
        <div class="resource-browse-header__title-group">
            <h1 class="resource-browse-header__title">
                <?php if ($hasQuery): ?>
                    <?php echo $escape(sprintf($translate('Resultados para "%s"'), $query)); ?>
                <?php else: ?>
                    <?php echo $escape($translate('Buscar')); ?>
                <?php endif; ?>
            </h1>
            <?php if ($hasQuery && $totalItems > 0): ?>
                <p class="resource-browse-header__subtitle">
                    <?php echo $escape(sprintf(
                        $totalItems === 1 ? $translate('%s recurso encontrado') : $translate('%s recursos encontrados'),
                        $totalItems
                    )); ?>
                </p>
            <?php endif; ?>
        </div>
    </header>

    <?php if (!$hasQuery): ?>
        <p><?php echo $escape($translate('Introduce un término de búsqueda.')); ?></p>

    <?php elseif (empty($results) || (!$itemList && empty($results['site_pages']['resources']) && empty($results['item_sets']['resources']))): ?>
        <p><?php echo $escape($translate('No result found')); ?></p>

    <?php else: ?>

        <?php if ($itemList): ?>
            <ul class="resources resource-grid" data-disable-masonry="true">
                <?php foreach ($itemList as $item): ?>
                    <?php
                    $title         = $item->displayTitle(null, $valueLang);
                    $resourceUrl   = $item->siteUrl();
                    $thumbnail     = $this->thumbnail($item, 'large');
                    $resourceType  = $item->value('lrmi:learningResourceType');
                    $eduLevel      = $getFirstValue($item, ['lrmi:educationalLevel', 'lom:educationalLevel']);
                    $topic         = $getFirstValue($item, ['schema:about', 'dcterms:subject']);
                    $body          = $bodyTerm
                        ? $item->value($bodyTerm, ['lang' => $valueLang])
                        : $item->displayDescription(null, $valueLang);
                    $summary       = trim(preg_replace('/\s+/u', ' ', strip_tags((string) $body)));
                    $createdDate   = $item->created();
                    $daysAgo       = ($createdDate instanceof DateTimeInterface)
                        ? (new DateTimeImmutable('now'))->diff($createdDate)->days
                        : null;
                    ?>
                    <li class="item resource resource-card">
                        <div class="resource-card__media">
                            <a class="resource-card__media-link" href="<?php echo $escapeAttr($resourceUrl); ?>">
                                <?php if ($thumbnail): ?>
                                    <?php echo $thumbnail; ?>
                                <?php else: ?>
                                    <span class="resource-card__media-fallback">
                                        <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                                    </span>
                                <?php endif; ?>
                            </a>
                            <?php if ($resourceType): ?>
                                <div class="resource-card__badge">
                                    <?php echo $this->partial('common/resource-type-badge', [
                                        'resourceTypeValue' => $resourceType,
                                        'class'             => 'resource-type-badge--overlay',
                                    ]); ?>
                                </div>
                            <?php endif; ?>
                        </div>

                        <div class="resource-card__body">
                            <?php if ($topic): ?>
                                <p class="resource-card__eyebrow"><?php echo $escape($displayValue($topic)); ?></p>
                            <?php endif; ?>

                            <h2 class="resource-card__title">
                                <a href="<?php echo $escapeAttr($resourceUrl); ?>"><?php echo $escape($title); ?></a>
                            </h2>

                            <div class="resource-card__meta">
                                <?php if ($eduLevel): ?>
                                    <span class="resource-level-pill"><?php echo $escape($displayValue($eduLevel)); ?></span>
                                <?php endif; ?>
                            </div>

                            <?php if ($summary !== ''): ?>
                                <p class="resource-card__summary"><?php echo $escape($summary); ?></p>
                            <?php endif; ?>

                            <?php if ($daysAgo !== null): ?>
                                <div class="resource-catalog-footer">
                                    <span class="resource-days-ago">
                                        <?php echo $escape(sprintf(
                                            $translate($daysAgo === 1 ? '%s day ago' : '%s days ago'),
                                            $daysAgo
                                        )); ?>
                                    </span>
                                </div>
                            <?php endif; ?>
                        </div>
                    </li>
                <?php endforeach; ?>
            </ul>

            <?php if ($totalItems > count($itemList)): ?>
                <p class="search-view-all">
                    <?php echo $hyperlink(
                        sprintf($translate('Ver todos los resultados (%s recursos)'), $totalItems),
                        $url(
                            'site/resource',
                            ['controller' => 'item', 'action' => 'browse'],
                            ['query' => ['fulltext_search' => $query]],
                            true
                        )
                    ); ?>
                </p>
            <?php endif; ?>
        <?php endif; ?>

        <?php foreach (['site_pages' => 'Páginas del sitio', 'item_sets' => 'Colecciones'] as $type => $label):
            if (empty($results[$type]['resources'])) continue; ?>
            <section class="search-resource-group">
                <h2 class="search-resource-group__title"><?php echo $escape($translate($label)); ?></h2>
                <ul class="search-resource-group__list">
                    <?php foreach ($results[$type]['resources'] as $resource): ?>
                        <li><?php echo $resource->link($resource->displayTitle(null, $valueLang) ?: $resource->title()); ?></li>
                    <?php endforeach; ?>
                </ul>
                <?php if ($results[$type]['total'] > count($results[$type]['resources'])): ?>
                    <p><?php echo $hyperlink(
                        sprintf($translate('Ver todos (%s)'), $results[$type]['total']),
                        $url(
                            'site/resource',
                            ['controller' => $type === 'site_pages' ? 'page' : 'item-set', 'action' => 'browse'],
                            ['query' => ['fulltext_search' => $query]],
                            true
                        )
                    ); ?></p>
                <?php endif; ?>
            </section>
        <?php endforeach; ?>

    <?php endif; ?>

</section>

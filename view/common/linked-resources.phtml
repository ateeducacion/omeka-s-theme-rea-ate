<?php
// Set up pagination.
$pagination = $this->pagination(null, $totalCount, $page, $perPage);
$fragment = 'resources-linked';
$pagination->setFragment($fragment);

// Set up locale.
$valueLang = null;
if ($this->status()->isSiteRequest()) {
    $lang = $this->lang();
    $filterLocale = (bool) $this->siteSetting('filter_locale_values');
    $valueLang = $filterLocale ? [$lang, ''] : null;
}

$labelMap = [
    'items' => 'Items', // @translate
    'item_sets' => 'Item sets', // @translate
    'media' => 'Media', // @translate
];

$escape     = $this->plugin('escapeHtml');
$escapeAttr = $this->plugin('escapeHtmlAttr');
?>
<div id="linked-resources">

<?php foreach ($subjectValues as $values): ?>
    <?php
    $caption = sprintf(
        $this->translate('%s with "%s: %s"'),
        $this->translate($labelMap[$resourceType]),
        $values[0]['property_alternate_label'] ?? $this->translate($values[0]['property_label']),
        $objectResource->displayTitle()
    );
    ?>
    <div class="linked-resource-group">
        <h6 class="linked-resource-heading"><?php echo $escape($caption); ?></h6>
        <div class="linked-resource-list">
            <?php foreach ($values as $value): ?>
                <?php
                $linked = $value['val']->resource();
                if (!$linked) continue;
                $thumb       = $linked->thumbnailDisplayUrl('square');
                $title       = $linked->displayTitle(null, $valueLang);
                $url         = $linked->siteUrl();
                $description = $linked->value('dcterms:description');
                ?>
                <div class="linked-resource resource item">
                    <div class="resource-heading">
                        <a class="resource-link" href="<?php echo $escapeAttr($url); ?>"><?php echo $escape($title); ?></a>
                    </div>
                    <div class="resource-thumbnail">
                        <a href="<?php echo $escapeAttr($url); ?>" tabindex="-1" aria-hidden="true">
                            <?php if ($thumb): ?>
                                <div class="image-parent"><img src="<?php echo $escapeAttr($thumb); ?>" alt=""></div>
                            <?php else: ?>
                                <div class="image-parent image-parent--placeholder">
                                    <span class="material-symbols-outlined" aria-hidden="true">description</span>
                                </div>
                            <?php endif; ?>
                        </a>
                    </div>
                    <?php if ($description): ?>
                        <div class="resource-body resource-metadata">
                            <div class="description"><?php echo $escape((string) $description); ?></div>
                        </div>
                    <?php endif; ?>
                    <div class="property-meta-group">
                        <?php echo $this->partial('common/resource-type-badge', ['resource' => $linked]); ?>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
<?php endforeach; ?>

<?php echo ($totalCount > $perPage) ? '<div class="linked-footer">' . $pagination . '</div>' : ''; ?>

</div>

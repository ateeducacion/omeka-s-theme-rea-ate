<?php
$escHtml = $this->plugin('escapeHtml');
$escAttr = $this->plugin('escapeHtmlAttr');
$htmlAllowlist = $this->plugin('htmlAllowlist');

// These three settings are HtmlTextarea fields, so they are meant to contain markup and
// cannot simply be escaped. They are reduced to a prose allowlist instead: formatting and
// http(s)/mailto links survive, script/iframe/form subtrees, on* handlers and style
// attributes do not. See helper/HtmlAllowlist.php and the README security note.
$footerLogo      = $this->themeSetting( 'footer_logo' );
$footerSiteInfo  = $htmlAllowlist( $this->themeSetting( 'footer_site_info' ) );
$footerMenu      = $this->themeSetting( 'footer_menu' );
$footerMenuDepth = $this->themeSetting('footer_menu_depth');
$footerContent   = $htmlAllowlist( $this->themeSetting( 'footer_content' ) );
$additional_classes = '';

if ( ! $footerMenu ) {
	$additional_classes .= ' no-menu';
} elseif ( ! $footerLogo && ! $footerSiteInfo && ! $footerContent ) {
	$additional_classes .= ' menu-only';
}

if ( $footerMenu && ( $footerLogo || $footerSiteInfo ) && $footerContent ) {
	$additional_classes .= ' all-columns';

	if ( $footerMenuDepth > 1 ) {
		$additional_classes .= ' menu-depth-2';
	}
}
?>

<footer class="main-footer">

	<!-- Footer Top -->
	<?php if ( $footerLogo || $footerSiteInfo || $footerMenu || $footerContent ): ?>
		<div class="main-footer__top">
			<div class="container main-footer__top-container <?php echo $additional_classes; ?>">

				<!-- Column 1 -->
				<?php if ( $footerLogo || $footerSiteInfo ) : ?>

					<div class="main-footer__col1">
						<?php if ( $footerLogo ): ?>
							<img
								src="<?php echo $escAttr( $this->themeSettingAssetUrl( 'footer_logo' ) ); ?>"
								alt="<?php echo $escHtml( $site->title() ); ?>"
								<?php if ($footerSiteInfo): ?>class="main-footer__logo--with-info"<?php endif; ?> />
						<?php endif; ?>

						<div class="footer_site_info">
							<?php if ( $footerSiteInfo ) : ?>
								<?php echo $footerSiteInfo; ?>
							<?php endif; ?>
						</div>
					</div>
					
				<?php endif; ?>

				<!-- Column 2 -->
				<?php if ( $footerMenu ) : ?>
				
					<div class="main-footer__col2">
						<?php
							echo $site->publicNav()->menu()->renderMenu(null, [
								'maxDepth' => $footerMenuDepth - 1
							]);
						?>
					</div>

				<?php endif; ?>

				<!-- Column 3 -->
				<?php if ( $footerContent ) : ?>

					<div class="main-footer__col3">
						<?php if ( $footerContent ) : ?>
							<?php echo $footerContent; ?>
						<?php endif; ?>
					</div>

				<?php endif; ?>

			</div>
		</div>
	<?php endif; ?>

	<!-- Footer Bottom -->
	<div class="main-footer__bottom">
		<div class="container main-footer__bottom-container">

			<!-- Copyright -->
			<div class="main-footer__copyright">
				<?php if ( $footer_copyright = $htmlAllowlist( $this->themeSetting( 'footer_copyright' ) ) ) : ?>
					<?php echo $footer_copyright; ?>
				<?php else: ?>
					<?php echo $this->translate( 'Powered by Omeka S' ); ?>
				<?php endif; ?>
			</div>
		</div>
	</div>

</footer>

<?php
$escHtml = $this->plugin('escapeHtml');
$escAttr = $this->plugin('escapeHtmlAttr');

$closeText = $this->translate('Close');
$previousText = $this->translate('Previous');

// Inside a <script> block, json_encode() alone is not enough: a string containing
// "</script>" would close the block and let the rest of the catalogue entry be parsed
// as markup. The HEX flags encode <, >, &, ' and " so no delimiter can survive.
$jsonFlags = JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE;
?>
<nav id="menu-drawer" class="menu-drawer" aria-hidden="true" inert style="display: none;">
	<div class="wrap">

		<div class="navigation-controls">
			<a href="."
				id="menu-backer"
				class="menu-backer is-empty"
				aria-label="<?php echo $escAttr($closeText); ?>"
				title="<?php echo $escAttr($closeText); ?>"
			>
                <?php echo $escHtml($closeText); ?>
			</a>
		</div><!-- .navigation-controls -->

		<div id="menu-clones" class="menu-container">

			<?php
			// menus placed here via Javascript (see: asset/js/navigation.js)
			?>

		</div><!-- .menu-container -->

	</div><!-- .wrap -->
</nav><!-- menu-drawer -->

<script>
    const closeText = <?php echo json_encode($closeText, $jsonFlags); ?>;
    const previousText = <?php echo json_encode($previousText, $jsonFlags); ?>;
</script>

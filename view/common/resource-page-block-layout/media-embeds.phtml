<?php
$resourceMedia = $resource->media();
$decoration = $this->themeSetting('image_decoration');
?>
<?php if ($resourceMedia): ?>
<div class="media-embeds <?php echo is_array($decoration) && in_array('media', $decoration) ? 'decoration' : ''; ?>">
    <h3 class="item-media-label"><?php echo $this->translate('Media'); ?></h3>
    <div class="media-grid masonry-grid">
        <?php foreach ($resourceMedia as $media): ?>
            <?php
            $type = $media->renderer();
            if ($type === 'html'):
            ?>
                <div class="media-card media-card--html">
                    <div class="media-card-content">
                        <?php echo $media->render(); ?>
                    </div>
                </div>
            <?php elseif ($type === 'LearningObject'): ?>
                <div class="scorm-card">
                    <div class="scorm-card__header">
                        <div class="scorm-card__icon">
                            <span class="material-symbols-outlined" aria-hidden="true">interactive_space</span>
                        </div>
                        <div class="scorm-card__header-text">
                            <div class="scorm-card__type">SCORM</div>
                        </div>
                    </div>
                    <div class="scorm-card__body">
                        <?php echo $media->render(); ?>
                    </div>
                </div>
            <?php else: ?>
                <div class="media-card <?php echo ($type !== 'file') ? 'media-type-card' : ''; ?>">
                    <div class="media-card-content">
                        <?php echo $media->render(); ?>
                    </div>
                    <?php if ($type === 'file'): ?>
                    <div class="media-card-footer">
                        <a href="<?php echo $this->escapeHtml($media->originalUrl()); ?>" download class="media-download" title="<?php echo $this->translate('Download'); ?>">
                            <span class="material-symbols-outlined">download</span>
                        </a>
                    </div>
                    <?php endif; ?>
                </div>
            <?php endif; ?>
        <?php endforeach; ?>
    </div>
</div>
<?php endif; ?>
